{
  "name": "whitelabelburger",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "ios:mcd": "rm -rf ios && node ./scripts/switch-appJSON.js mcd && expo run:ios --device",
    "ios:bk": "rm -rf ios && node ./scripts/switch-appJSON.js bk && expo run:ios --device",
    "start:mcd": "node ./scripts/switch-appJSON.js mcd && expo start",
    "start:bk": "node ./scripts/sswitch-appJSON.js bk && expo start",
    "iosbuild:mcd": "node ./scripts/switch-appJSON.js mcd && node ./scripts/switch-credentials.js mcd && eas build --platform ios --profile development",
    "iosbuild:bk": "node ./scripts/switch-appJSON.js bk && node ./scripts/switch-credentials.js bk && eas build --platform ios --profile development",
    "android": "expo run:android",
    "web": "expo start --web",
    "lint": "expo lint",
    "reset-project": "node ./scripts/reset-project.js"
  },
  "dependencies": {
    "@expo/ui": "~57.0.4",
    "expo": "~57.0.4",
    "expo-constants": "~57.0.3",
    "expo-dev-client": "~57.0.5",
    "expo-device": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-glass-effect": "~57.0.0",
    "expo-image": "~57.0.0",
    "expo-linking": "~57.0.2",
    "expo-router": "~57.0.4",
    "expo-splash-screen": "~57.0.2",
    "expo-status-bar": "~57.0.0",
    "expo-symbols": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "expo-web-browser": "~57.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3"
  },
  "private": true
}
